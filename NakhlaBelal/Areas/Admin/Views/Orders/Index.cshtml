@model IEnumerable<NakhlaBelal.Models.Order>
@{
    ViewBag.Title = "Orders Management";
    var stats = ViewBag.Stats;
}

<div class="mobile-scroll-hint">
    <i class="fas fa-arrows-left-right"></i> اسحب يميناً أو يساراً لعرض كافة التفاصيل
</div>

<div class="page-header">
    <div>
        <h2>Orders</h2>
        <p>Manage and track all customer orders (@Model.Count() orders in this view)</p>
    </div>
    <div class="header-actions">
        <button class="btn btn-secondary" onclick="location.reload()">
            <i class="fas fa-sync"></i>
            <span class="btn-text">Refresh</span>
        </button>
        <a asp-action="Create" class="btn btn-primary">
            <i class="fas fa-plus"></i>
            <span class="btn-text">New Order</span>
        </a>
    </div>
</div>

<div class="orders-stats-container">
    <div class="orders-stat-card">
        <div class="orders-stat-title">Total Orders</div>
        <div class="orders-stat-value">@stats.Total</div>
        <div class="orders-stat-desc">Active orders in system</div>
    </div>
    <div class="orders-stat-card">
        <div class="orders-stat-title">Revenue</div>
        <div class="orders-stat-value">@stats.Revenue.ToString("N2") EGP</div>
        <div class="orders-stat-desc">Excluding cancelled</div>
    </div>
    <div class="orders-stat-card">
        <div class="orders-stat-title">Pending Orders</div>
        <div class="orders-stat-value">@stats.Pending</div>
        <div class="orders-stat-desc badge-warning-text">Require attention</div>
    </div>
    <div class="orders-stat-card">
        <div class="orders-stat-title">Shipped</div>
        <div class="orders-stat-value">@stats.Shipped</div>
        <div class="orders-stat-desc">On the way to customers</div>
    </div>
</div>

<div class="filters">
    <div class="filter-group">
        <a href="@Url.Action("Index", new { status = "" })"
               class="filter-btn @(string.IsNullOrEmpty(ViewBag.CurrentStatus) ? "active" : "")">
            <span>All Orders</span>
        </a>
        <a href="@Url.Action("Index", new { status = "Pending" })"
               class="filter-btn @(ViewBag.CurrentStatus == "Pending" ? "active" : "")">
            <span>Pending</span>
        </a>
        <a href="@Url.Action("Index", new { status = "Shipped" })"
               class="filter-btn @(ViewBag.CurrentStatus == "Shipped" ? "active" : "")">
            <span>Shipped</span>
        </a>
        <a href="@Url.Action("Index", new { status = "Delivered" })"
               class="filter-btn @(ViewBag.CurrentStatus == "Delivered" ? "active" : "")">
            <span>Delivered</span>
        </a>
    </div>
    <div class="action-buttons">
        <button class="btn btn-secondary" onclick="window.print()">
            <i class="fas fa-download"></i>
            <span class="btn-text">Print Report</span>
        </button>
    </div>
</div>

<div class="data-table-container">
    <div class="table-header">
        <h2>Recent Orders</h2>
        <div class="table-actions" id="bulkActions" style="display:none;">
            <button class="table-action text-danger" onclick="deleteSelected()">
                <i class="fas fa-trash"></i>
                <span class="btn-text">Delete Selected</span>
            </button>
        </div>
    </div>

    <table class="data-table">
        <thead>
            <tr>
                <th style="width: 40px;">
                    <input type="checkbox" id="selectAll" onchange="toggleSelectAll(this)">
                </th>
                <th>Order Number</th>
                <th>Customer</th>
                <th>Products</th>
                <th>Date</th>
                <th>Total</th>
                <th>Status</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr data-order-id="@item.Id">
                    <td>
                        <input type="checkbox" class="order-select" value="@item.Id" onchange="updateSelection()">
                    </td>
                    <td>
                        <div class="order-id">#@item.OrderNumber</div>
                        <small class="text-muted">@item.PaymentMethod</small>
                    </td>
                    <td>
                        <div class="customer-name">@item.FullName</div>
                        <div class="text-muted" style="font-size: 0.8rem;">@item.ShippingEmail</div>
                    </td>
                    <td>
                        <div class="order-product-info">
                            @if (item.OrderItems != null && item.OrderItems.Any())
                            {
                                <div class="order-product-name">@item.OrderItems.First().Product?.Name</div>
                                @if (item.OrderItems.Count > 1)
                                {
                                    <div class="order-product-desc">+ @(item.OrderItems.Count - 1) other items</div>
                                }
                            }
                            else
                            {
                                <div class="text-muted">No items</div>
                            }
                        </div>
                    </td>
                    <td>
                        <div class="order-date">@item.CreatedAt.ToString("MMM dd, yyyy")</div>
                        <small class="text-muted">@item.CreatedAt.ToString("hh:mm tt")</small>
                    </td>
                    <td>
                        <div class="order-total-amount">@item.TotalAmount.ToString("N2") EGP</div>
                    </td>
                    <td>
                        @{
                            var statusClass = item.OrderStatus.ToLower() switch
                            {
                                "pending" => "order-status-pending",
                                "paid" => "order-status-paid",
                                "shipped" => "order-status-shipping", // مابينج مع كلاسات الـ CSS تبعك
                                "delivered" => "order-status-paid",
                                "cancelled" => "order-status-cancelled",
                                _ => "order-status-pending"
                            };
                        }
                        <span class="order-status-badge @statusClass">@item.OrderStatus</span>
                    </td>
                    <td>
                        <div class="row-actions">
                            @* عرض سريع بالـ Modal *@
                            <button class="row-action view" onclick="openOrderModal('@item.Id')">
                                <i class="fas fa-eye"></i>
                            </button>
                            @* انتقال لصفحة التفاصيل الكاملة *@
                            <a asp-action="Details" asp-route-id="@item.Id" class="row-action edit">
                                <i class="fas fa-edit"></i>
                            </a>
                            <button class="row-action delete" onclick="deleteOrder('@item.Id')">
                                <i class="fas fa-trash"></i>
                            </button>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

@section Scripts {
    <script>
        // اختيار الكل
        function toggleSelectAll(source) {
            checkboxes = document.getElementsByClassName('order-select');
            for (var i = 0; i < checkboxes.length; i++) {
                checkboxes[i].checked = source.checked;
            }
            updateSelection();
        }

        // تحديث شريط العمليات الجماعية
        function updateSelection() {
            var selectedCount = document.querySelectorAll('.order-select:checked').length;
            var bulkActions = document.getElementById('bulkActions');
            if (selectedCount > 0) {
                bulkActions.style.display = 'flex';
            } else {
                bulkActions.style.display = 'none';
            }
        }

        // حذف طلب واحد
        function deleteOrder(id) {
            if (confirm('Are you sure you want to delete this order?')) {
                $.post('@Url.Action("Delete", "Orders")', { id: id }, function (data) {
                    if (data.success) {
                        location.reload();
                    } else {
                        alert(data.message);
                    }
                });
            }
        }

        // حذف جماعي (نفس منطق البرودكت)
        function deleteSelected() {
            var selectedIds = Array.from(document.querySelectorAll('.order-select:checked')).map(cb => parseInt(cb.value));
            if (selectedIds.length > 0 && confirm('Delete ' + selectedIds.length + ' orders?')) {
                $.ajax({
                    url: '@Url.Action("DeleteMultiple", "Orders")',
                    type: 'POST',
                    contentType: 'application/json',
                    data: JSON.stringify(selectedIds),
                    success: function (data) {
                        if (data.success) location.reload();
                    }
                });
            }
        }

        // فتح الـ Modal (تحتاج لتجهيز ميثود GetDetails في الكنترولر ترجع PartialView)
        function openOrderModal(id) {
             $.get('@Url.Action("GetDetails", "Orders")/' + id, function(data) {
                 // هنا تضع الكود لفتح الـ Modal وعرض الـ data داخله
                 // مثال: $('#orderModalBody').html(data); $('#orderModal').modal('show');
                 alert("فتح تفاصيل الطلب رقم: " + id);
             });
        }
    </script>
}