@model NakhlaBelal.ViewModels.CheckoutVM

<div class="container py-5">
    <h2 class="text-center mb-5">CHECKOUT</h2>
    <form asp-action="ProcessOrder" method="post">
        

        @* لاحظ هنا سنرسل البيانات لـ Pay *@
        <div class="row">
            <div class="col-md-7">
                <div class="card p-4 shadow-sm TableContainerCheck">
                    <h4>Billing Details</h4>
                    <hr />
                    <div class="row">
                        <div class="form-group col-md-6 mb-3">
                            <label asp-for="ShippingFirstName">First Name *</label>
                            <input asp-for="ShippingFirstName" class="form-control" />
                            <span asp-validation-for="ShippingFirstName" class="text-danger"></span>
                        </div>
                        <div class="form-group col-md-6 mb-3">
                            <label asp-for="ShippingLastName">Last Name *</label>
                            <input asp-for="ShippingLastName" class="form-control" />
                            <span asp-validation-for="ShippingLastName" class="text-danger"></span>
                        </div>
                        <div class="form-group col-md-6 mb-3">
                            <label asp-for="ShippingAddress">Street Address *</label>
                            <input asp-for="ShippingAddress" class="form-control" />
                            <span asp-validation-for="ShippingAddress" class="text-danger"></span>
                        </div>
                        <div class="form-group col-md-6 mb-3">
                            <label asp-for="ShippingCity">Town / City *</label>
                            <input asp-for="ShippingCity" class="form-control" />
                            <span asp-validation-for="ShippingCity" class="text-danger"></span>
                        </div>
                        <div class="form-group col-md-6 mb-3">
                            <label asp-for="ShippingState">State *</label>
                            <input asp-for="ShippingState" class="form-control" />
                            <span asp-validation-for="ShippingState" class="text-danger"></span>
                        </div>

                        <div class="form-group col-md-6 mb-3">
                            <label asp-for="ShippingZipCode">Postcode / ZIP *</label>
                            <input asp-for="ShippingZipCode" class="form-control" />
                            <span asp-validation-for="ShippingZipCode" class="text-danger"></span>
                        </div>
                        <div class="form-group col-md-6 mb-3">
                            <label asp-for="ShippingPhone">Phone *</label>
                            <input asp-for="ShippingPhone" class="form-control" />
                            <span asp-validation-for="ShippingPhone" class="text-danger"></span>
                        </div>
                        <div class="form-group col-md-6 mb-3">
                            <label asp-for="ShippingEmail">Email *</label>
                            <input asp-for="ShippingEmail" class="form-control" />
                            <span asp-validation-for="ShippingEmail" class="text-danger"></span>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-md-5">
                <div class="card p-4 shadow-sm TableContainerCheck">
                    <h4>Your Order</h4>
                    <table class="table mt-3">
                        <thead>
                            <tr>
                                <th class="TableContainerCheck">Product</th>
                                <th class="text-end TableContainerCheck">Subtotal</th>
                            </tr>
                        </thead>
                        <tbody class="">
                            @if (Model.CartData != null && Model.CartData.CartItems.Any())
                            {
                                @foreach (var item in Model.CartData.CartItems)
                                {
                                    <tr class="">
                                        <td class="TableContainerCheck">@item.Product.Name × @item.Count</td>
                                        <td class="text-end TableContainerCheck">€ @((item.Product.Price * item.Count).ToString("N2"))</td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr><td colspan="2">Your cart is empty</td></tr>
                            }
                        </tbody>
                        <tfoot class="fw-bold">
                            <tr class="">
                                <td class="TableContainerCheck">Subtotal</td>
                                <td class="text-end TableContainerCheck">€ @Model.CartData.Subtotal.ToString("N2")</td>
                            </tr>
                        </tr>
                        @if (Model.CartData.Discount > 0)
                        {
                            <tr class="text-danger ">
                                <td class="TableContainerCheck">Discount (@Model.CartData.PromotionCode)</td>
                                <td class="text-end TableContainerCheck">- € @Model.CartData.Discount.ToString("N2")</td>
                            </tr>
                        }
                        @if (Model.CartData.Tax > 0)
                        {
                            <tr>
                                <td class="TableContainerCheck">VAT (19%)</td>
                                <td class="text-end TableContainerCheck">€ @Model.CartData.Tax.ToString("N2")</td>
                            </tr>
                        }
                        <tr>
                            <tr>
                                <td class="TableContainerCheck">Shipping</td>
                                <td class="text-end TableContainerCheck">€ @Model.CartData.Shipping.ToString("N2")</td>
                            </tr>
                            <tr class="text-primary h5 ">
                                <td class="TableContainerCheck">Total</td>
                                <td class="text-end TableContainerCheck">€ @Model.CartData.Total.ToString("N2")</td>
                            </tr>
                        </tfoot>
                    </table>

                    <div class="mt-4">
                        <button type="submit" class="checkout-btn">PLACE ORDER</button>
                    </div>
                </div>
            </div>
        </div>
    </form>
</div>