@{
    ViewData["Title"] = "Order Confirmation";
}

<div class="container my-5 py-5">
    <div class="row justify-content-center">
        <div class="col-md-8 text-center">
            <div class="mb-4">
                <svg xmlns="http://www.w3.org/2000/svg" width="100" height="100" fill="#198754" class="bi bi-check-circle-fill shadow-sm rounded-circle" viewBox="0 0 16 16">
                    <path d="M16 8A8 8 0 1 1 0 8a8 8 0 0 1 16 0zm-3.97-3.03a.75.75 0 0 0-1.08.022L7.477 9.417 5.384 7.323a.75.75 0 0 0-1.06 1.06L6.97 11.03a.75.75 0 0 0 1.079-.02l3.992-4.99a.75.75 0 0 0-.01-1.05z"/>
                </svg>
            </div>

            <h1 class="display-4 fw-bold mb-3" style="letter-spacing: -1px;">THANK YOU!</h1>
            <p class="lead text-muted mb-5">
                We have successfully received your order. One of our team members will review your information and get back to you within the next 48 hours.
            </p>

            <div class="card border-0 shadow-sm bg-light p-4 mb-5">
                <div class="row text-start">
                    <div class="col-sm-4 mb-3 mb-sm-0">
                        <small class="text-uppercase text-muted d-block fw-bold">Order Number:</small>
                        <span class="fw-bold text-dark">#@DateTime.Now.ToString("yyyy")-@Guid.NewGuid().ToString("N").Substring(0, 5).ToUpper()</span>
                    </div>
                    <div class="col-sm-4 mb-3 mb-sm-0">
                        <small class="text-uppercase text-muted d-block fw-bold">Order Date:</small>
                        <span class="fw-bold text-dark">@DateTime.Now.ToString("MMMM dd, yyyy")</span>
                    </div>
                    <div class="col-sm-4">
                        <small class="text-uppercase text-muted d-block fw-bold">Payment Method:</small>
                        <span class="fw-bold text-dark">Bank Transfer</span>
                    </div>
                </div>
            </div>

            <div class="d-grid d-sm-flex justify-content-sm-center gap-3">
                <a asp-area="Customer" asp-controller="Home" asp-action="Index" class="btn btn-dark btn-lg px-5 py-3 fw-bold shadow-sm">
                    CONTINUE SHOPPING
                </a>
                <button onclick="window.print()" class="btn btn-outline-secondary btn-lg px-4 py-3 fw-bold">
                    PRINT RECEIPT
                </button>
            </div>
        </div>
    </div>
</div>

<style>
    body {
        background-color: #f8f9fa; /* لون خلفية هادئ */
    }
    .display-4 {
        color: #212529;
    }
    .btn-dark {
        background-color: #002211; /* أخضر غامق جداً مثل تصميمك */
        border: none;
        transition: all 0.3s ease;
    }
    .btn-dark:hover {
        background-color: #004422;
        transform: translateY(-2px);
    }
</style>